{
	"push": {
		"master": {
			"distribute": {
				"docker": "develop",
				"npm": "$version-snapshot"
			},
			"deploy": {
				"managerTag": "develop,test1, test2",
				"environment": "staging"
			}
		}
	},
	"release": {
		"distribute": {
			"docker": "latest,$version",
			"npm": "$version"
		},
		"deploy": {
			"managerTag": "latest",
			"environment": "demo"
		}
	}
}
